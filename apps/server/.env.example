# Node environment: development | test | production
NODE_ENV=development

# --- Required in production (boot fails if unset) ---
# Server host/port
HOST=0.0.0.0
PORT=8080
# Allowed CORS origin (the client app)
CORS_ORIGIN=http://localhost:3000

# --- Optional (have safe defaults) ---
# Route prefix where Swagger UI is served
SWAGGER_UI_PREFIX=/swagger-ui
